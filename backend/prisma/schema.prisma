generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum RoleName {
  FARMER
  VENDOR
  EXPERT
  TEACHER
  ADMIN
  NGO
  GOV
  SUPER_ADMIN
}

enum OtpPurpose {
  LOGIN
  VERIFY_EMAIL
  VERIFY_PHONE
  PASSWORD_RESET
}

enum OtpChannel {
  EMAIL
  SMS
  VOICE
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS
  GROUP
  PRIVATE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  REMOVED
}

enum ReactionType {
  LIKE
  CELEBRATE
  LEARN
  QUESTION
  SUPPORT
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum GroupMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum ChatRoomType {
  DIRECT
  GROUP
  CONSULTATION
}

enum MessageKind {
  TEXT
  IMAGE
  VIDEO
  VOICE
  LOCATION
  SYSTEM
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  FULFILLING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  AUDIO
  ARTICLE
  PDF
  QUIZ
  LIVE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CertificateStatus {
  ISSUED
  EXPIRED
  REVOKED
}

enum FarmMemberRole {
  OWNER
  MANAGER
  WORKER
  VIEWER
}

enum CropCycleStatus {
  PLANNED
  ACTIVE
  HARVESTED
  FAILED
  ARCHIVED
}

enum FarmTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum FinanceRecordType {
  EXPENSE
  INCOME
}

enum AiProvider {
  OPENAI
  ANTHROPIC
  GEMINI
}

enum AiMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum AiConversationStatus {
  ACTIVE
  ESCALATED
  CLOSED
}

enum AiDocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum AiAnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SessionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum CertificationApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  INSPECTION_SCHEDULED
  APPROVED
  REJECTED
  ISSUED
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  PASSED
  FAILED
  NEEDS_REVIEW
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

model User {
  id              String      @id @default(uuid())
  email           String?     @unique
  phone           String?     @unique
  passwordHash    String
  displayName     String?
  firstName       String?
  lastName        String?
  avatarUrl       String?
  bio             String?
  locale          String      @default("km-KH")
  province        String?
  district        String?
  commune         String?
  village         String?
  status          UserStatus  @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  roles               UserRole[]
  refreshTokens       RefreshToken[]
  otpTokens           OtpToken[]
  posts               Post[]
  comments            Comment[]
  reactions           Reaction[]
  following           Follow[]               @relation("UserFollowing")
  followers           Follow[]               @relation("UserFollowers")
  groupsOwned         Group[]
  groupMemberships    GroupMember[]
  chatParticipants    ChatParticipant[]
  chatMessages        ChatMessage[]
  vendorProfile       VendorProfile?
  products            Product[]
  cart                Cart?
  orders              Order[]
  productReviews      ProductReview[]
  coursesTaught       Course[]
  enrollments         Enrollment[]
  learningCertificates LearningCertificate[]
  ownedFarms          Farm[]                 @relation("FarmOwner")
  farmMemberships     FarmMember[]
  aiConversations     AiConversation[]
  aiMessages          AiMessage[]
  aiDocuments         AiDocument[]
  aiUsageLogs         AiUsageLog[]
  cropDiseaseAnalyses CropDiseaseAnalysis[]
  expertProfile       ExpertProfile?
  consultationBookings ConsultationBooking[]
  consultationMessages ConsultationMessage[]
  certificationApplications CertificationApplication[]
  inspections         CertificationInspection[]
  farmCertificates    FarmCertificate[]
  notifications       Notification[]
  notificationPreferences NotificationPreference[]
  deviceTokens        DeviceToken[]
  mediaAssets         MediaAsset[]

  @@index([status, createdAt])
  @@index([province, district])
  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  name        RoleName   @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("refresh_tokens")
}

model OtpToken {
  id         String     @id @default(uuid())
  userId     String?
  target     String
  channel    OtpChannel
  purpose    OtpPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([target, purpose, expiresAt])
  @@map("otp_tokens")
}

model MediaAsset {
  id          String   @id @default(uuid())
  ownerId     String?
  bucket      String
  objectKey   String
  url         String?
  mimeType    String
  sizeBytes   Int?
  width       Int?
  height      Int?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@map("media_assets")
}

model Post {
  id           String         @id @default(uuid())
  authorId     String
  groupId      String?
  content      String
  media        Json           @default("[]")
  visibility   PostVisibility @default(PUBLIC)
  status       ContentStatus  @default(PUBLISHED)
  locationName String?
  latitude     Float?
  longitude    Float?
  cropTags     Json           @default("[]")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group     Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  comments  Comment[]
  reactions Reaction[]

  @@index([authorId, status, createdAt])
  @@index([groupId, status, createdAt])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String        @id @default(uuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  status    ContentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Comment[] @relation("CommentReplies")
  reactions Reaction[]

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@map("comments")
}

model Reaction {
  id        String       @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([postId, type])
  @@index([commentId, type])
  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@map("reactions")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
  @@map("follows")
}

model Group {
  id          String          @id @default(uuid())
  ownerId     String
  name        String
  slug        String          @unique
  description String?
  visibility  GroupVisibility @default(PUBLIC)
  province    String?
  cropTags    Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  owner   User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMember[]
  posts   Post[]

  @@index([visibility, createdAt])
  @@index([province])
  @@map("groups")
}

model GroupMember {
  id        String          @id @default(uuid())
  groupId   String
  userId    String
  role      GroupMemberRole @default(MEMBER)
  joinedAt  DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, joinedAt])
  @@map("group_members")
}

model ChatRoom {
  id        String       @id @default(uuid())
  type      ChatRoomType @default(DIRECT)
  title     String?
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([type, updatedAt])
  @@map("chat_rooms")
}

model ChatParticipant {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  joinedAt  DateTime @default(now())
  mutedAt   DateTime?
  lastReadAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId, joinedAt])
  @@map("chat_participants")
}

model ChatMessage {
  id        String      @id @default(uuid())
  roomId    String
  senderId  String
  kind      MessageKind @default(TEXT)
  content   String?
  media     Json        @default("[]")
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now())
  deletedAt DateTime?

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([senderId, createdAt])
  @@map("chat_messages")
}

model VendorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  businessName    String
  description     String?
  verificationStatus String @default("PENDING")
  commissionRate  Decimal  @default(0.10) @db.Decimal(5, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vendor_profiles")
}

model ProductCategory {
  id        String   @id @default(uuid())
  parentId  String?
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@index([parentId])
  @@map("product_categories")
}

model Product {
  id            String        @id @default(uuid())
  vendorId      String
  categoryId    String?
  name          String
  slug          String        @unique
  description   String?
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("KHR")
  stockQuantity Int           @default(0)
  unit          String
  minOrderQty   Int           @default(1)
  images        Json          @default("[]")
  tags          Json          @default("[]")
  status        ProductStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  vendor    User             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category  ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants  ProductVariant[]
  cartItems CartItem[]
  orderItems OrderItem[]
  reviews   ProductReview[]

  @@index([vendorId, status, createdAt])
  @@index([categoryId, status])
  @@index([status, createdAt])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  sku       String?  @unique
  name      String
  price     Decimal? @db.Decimal(12, 2)
  stock     Int      @default(0)
  metadata  Json     @default("{}")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String
  status          OrderStatus @default(PENDING)
  currency        String      @default("KHR")
  subtotalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  deliveryAmount  Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @default(0) @db.Decimal(12, 2)
  shippingAddress Json        @default("{}")
  metadata        Json        @default("{}")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  buyer    User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  payments Payment[]

  @@index([buyerId, status, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  vendorId  String
  quantity  Int
  unit      String
  unitPrice Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  snapshot  Json     @default("{}")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([vendorId])
  @@map("order_items")
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String
  provider    String
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("KHR")
  providerRef String?
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@map("payments")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int
  comment   String?
  media     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId, rating])
  @@map("product_reviews")
}

model Course {
  id           String       @id @default(uuid())
  instructorId String
  title        String
  slug         String       @unique
  description  String?
  language     String       @default("km-KH")
  level        String?
  price        Decimal      @default(0) @db.Decimal(12, 2)
  currency     String       @default("KHR")
  status       CourseStatus @default(DRAFT)
  tags         Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime     @updatedAt

  instructor   User                  @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  modules      CourseModule[]
  lessons      Lesson[]
  enrollments  Enrollment[]
  certificates LearningCertificate[]

  @@index([instructorId, status])
  @@index([status, createdAt])
  @@map("courses")
}

model CourseModule {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  summary   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, sortOrder])
  @@map("course_modules")
}

model Lesson {
  id          String     @id @default(uuid())
  courseId    String
  moduleId    String?
  title       String
  type        LessonType @default(ARTICLE)
  content     String?
  mediaUrl    String?
  durationSec Int?
  sortOrder   Int        @default(0)
  isPreview   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module    CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  quizzes   Quiz[]
  progress  LessonProgress[]

  @@index([courseId, sortOrder])
  @@index([moduleId, sortOrder])
  @@map("lessons")
}

model Quiz {
  id        String   @id @default(uuid())
  lessonId  String
  title     String
  passScore Int      @default(70)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id        String   @id @default(uuid())
  quizId    String
  prompt    String
  options   Json
  answerKey Json
  sortOrder Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
  @@map("quiz_questions")
}

model Enrollment {
  id          String           @id @default(uuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progressPct Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]
  certificate  LearningCertificate?

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@map("enrollments")
}

model LessonProgress {
  id           String    @id @default(uuid())
  enrollmentId String
  lessonId     String
  completedAt  DateTime?
  progressPct  Int       @default(0)
  updatedAt    DateTime  @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model LearningCertificate {
  id           String            @id @default(uuid())
  userId       String
  courseId     String
  enrollmentId String            @unique
  certificateNo String           @unique
  qrToken      String            @unique
  pdfUrl       String?
  status       CertificateStatus @default(ISSUED)
  issuedAt     DateTime          @default(now())
  expiresAt    DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("learning_certificates")
}

model Farm {
  id              String    @id @default(uuid())
  ownerId          String
  name            String
  description     String?
  province        String?
  district        String?
  commune         String?
  village         String?
  address         String?
  areaHectares    Decimal?  @db.Decimal(12, 4)
  boundaryGeojson Json?
  boundary        Unsupported("geometry(MultiPolygon,4326)")?
  centroid        Unsupported("geometry(Point,4326)")?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner          User                    @relation("FarmOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members        FarmMember[]
  plots          FarmPlot[]
  cropCycles     CropCycle[]
  tasks          FarmTask[]
  financeRecords FarmFinanceRecord[]
  inventoryItems FarmInventoryItem[]
  harvests       Harvest[]
  aiAnalyses     CropDiseaseAnalysis[]
  certificationApplications CertificationApplication[]
  certificates   FarmCertificate[]

  @@index([ownerId, createdAt])
  @@index([province, district])
  @@map("farms")
}

model FarmMember {
  id        String         @id @default(uuid())
  farmId    String
  userId    String
  role      FarmMemberRole @default(VIEWER)
  joinedAt  DateTime       @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([farmId, userId])
  @@index([userId])
  @@map("farm_members")
}

model FarmPlot {
  id              String    @id @default(uuid())
  farmId          String
  name            String
  cropHint        String?
  areaHectares    Decimal?  @db.Decimal(12, 4)
  boundaryGeojson Json?
  boundary        Unsupported("geometry(Polygon,4326)")?
  centroid        Unsupported("geometry(Point,4326)")?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farm       Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropCycles CropCycle[]
  tasks      FarmTask[]
  aiAnalyses CropDiseaseAnalysis[]

  @@index([farmId])
  @@map("farm_plots")
}

model Crop {
  id        String   @id @default(uuid())
  name      String
  localName String?
  slug      String   @unique
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cropCycles CropCycle[]

  @@map("crops")
}

model CropCycle {
  id             String          @id @default(uuid())
  farmId         String
  plotId         String?
  cropId         String
  variety        String?
  status         CropCycleStatus @default(PLANNED)
  plantedAt      DateTime?
  expectedHarvestAt DateTime?
  harvestedAt    DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  farm     Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  plot     FarmPlot?  @relation(fields: [plotId], references: [id], onDelete: SetNull)
  crop     Crop       @relation(fields: [cropId], references: [id], onDelete: Restrict)
  tasks    FarmTask[]
  harvests Harvest[]

  @@index([farmId, status])
  @@index([plotId, status])
  @@index([cropId])
  @@map("crop_cycles")
}

model FarmTask {
  id          String         @id @default(uuid())
  farmId      String
  plotId      String?
  cropCycleId String?
  title       String
  description String?
  status      FarmTaskStatus @default(TODO)
  dueAt       DateTime?
  completedAt DateTime?
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  farm      Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  plot      FarmPlot?  @relation(fields: [plotId], references: [id], onDelete: SetNull)
  cropCycle CropCycle? @relation(fields: [cropCycleId], references: [id], onDelete: SetNull)

  @@index([farmId, status, dueAt])
  @@map("farm_tasks")
}

model FarmFinanceRecord {
  id          String            @id @default(uuid())
  farmId      String
  type        FinanceRecordType
  category    String
  amount      Decimal           @db.Decimal(12, 2)
  currency    String            @default("KHR")
  occurredAt  DateTime          @default(now())
  note        String?
  receiptUrl  String?
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId, type, occurredAt])
  @@map("farm_finance_records")
}

model FarmInventoryItem {
  id          String   @id @default(uuid())
  farmId      String
  name        String
  category    String
  quantity    Decimal  @default(0) @db.Decimal(12, 3)
  unit        String
  expiresAt   DateTime?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId, category])
  @@map("farm_inventory_items")
}

model Harvest {
  id          String   @id @default(uuid())
  farmId      String
  cropCycleId String
  quantity    Decimal  @db.Decimal(12, 3)
  unit        String
  grade       String?
  harvestedAt DateTime @default(now())
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropCycle CropCycle @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)

  @@index([farmId, harvestedAt])
  @@map("harvests")
}

model AiConversation {
  id        String               @id @default(uuid())
  userId    String?
  title     String?
  language  String               @default("km-KH")
  status    AiConversationStatus @default(ACTIVE)
  farmContext Json               @default("{}")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages  AiMessage[]
  usageLogs AiUsageLog[]
  analyses  CropDiseaseAnalysis[]

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String        @id @default(uuid())
  conversationId String
  userId         String?
  role           AiMessageRole
  content        String
  citations      Json          @default("[]")
  safetyFlags    Json          @default("[]")
  provider       AiProvider?
  model          String?
  tokenCount     Int?
  createdAt      DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_messages")
}

model AiDocument {
  id          String           @id @default(uuid())
  uploadedById String?
  title       String
  source      String?
  language    String           @default("km-KH")
  cropTags    Json             @default("[]")
  provinceTags Json            @default("[]")
  text        String?
  fileUrl     String?
  status      AiDocumentStatus @default(UPLOADED)
  metadata    Json             @default("{}")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  uploadedBy User?              @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  chunks     AiKnowledgeChunk[]

  @@index([status, language])
  @@index([uploadedById, createdAt])
  @@map("ai_documents")
}

model AiKnowledgeChunk {
  id            String   @id @default(uuid())
  documentId    String
  qdrantPointId String   @unique
  chunkIndex    Int
  content       String
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  document AiDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("ai_knowledge_chunks")
}

model AiUsageLog {
  id             String     @id @default(uuid())
  userId         String?
  conversationId String?
  provider       AiProvider
  model          String
  promptTokens   Int        @default(0)
  completionTokens Int      @default(0)
  totalTokens    Int        @default(0)
  latencyMs      Int?
  costUsd        Decimal?   @db.Decimal(12, 6)
  createdAt      DateTime   @default(now())

  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([provider, model, createdAt])
  @@map("ai_usage_logs")
}

model CropDiseaseAnalysis {
  id             String           @id @default(uuid())
  userId         String
  farmId         String?
  plotId         String?
  conversationId String?
  imageUrl       String
  cropName       String?
  status         AiAnalysisStatus @default(QUEUED)
  diagnosis      Json?
  confidence     Decimal?         @db.Decimal(5, 4)
  recommendation String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm         Farm?           @relation(fields: [farmId], references: [id], onDelete: SetNull)
  plot         FarmPlot?       @relation(fields: [plotId], references: [id], onDelete: SetNull)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([farmId, createdAt])
  @@map("crop_disease_analyses")
}

model ExpertProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  headline    String?
  bio         String?
  specialties Json @default("[]")
  languages   Json @default("[]")
  hourlyRate  Decimal  @default(0) @db.Decimal(12, 2)
  currency    String   @default("KHR")
  verifiedAt  DateTime?
  ratingAvg   Decimal  @default(0) @db.Decimal(3, 2)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules ExpertSchedule[]
  bookings  ConsultationBooking[]

  @@index([verifiedAt])
  @@map("expert_profiles")
}

model ExpertSchedule {
  id              String   @id @default(uuid())
  expertProfileId String
  weekday         Int
  startMinute     Int
  endMinute       Int
  timezone        String   @default("Asia/Phnom_Penh")
  createdAt       DateTime @default(now())

  expertProfile ExpertProfile @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)

  @@index([expertProfileId, weekday])
  @@map("expert_schedules")
}

model ConsultationBooking {
  id              String        @id @default(uuid())
  farmerId        String
  expertProfileId String
  status          BookingStatus @default(REQUESTED)
  topic           String
  scheduledAt     DateTime
  durationMinutes Int           @default(30)
  price           Decimal       @default(0) @db.Decimal(12, 2)
  currency        String        @default("KHR")
  aiSummary       String?
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  farmer        User              @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  expertProfile ExpertProfile     @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)
  session       ConsultationSession?
  review        ConsultationReview?

  @@index([farmerId, status, scheduledAt])
  @@index([expertProfileId, status, scheduledAt])
  @@map("consultation_bookings")
}

model ConsultationSession {
  id        String        @id @default(uuid())
  bookingId String        @unique
  status    SessionStatus @default(SCHEDULED)
  joinUrl   String?
  startedAt DateTime?
  endedAt   DateTime?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  booking  ConsultationBooking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  messages ConsultationMessage[]

  @@map("consultation_sessions")
}

model ConsultationMessage {
  id        String      @id @default(uuid())
  sessionId String
  senderId  String
  kind      MessageKind @default(TEXT)
  content   String?
  media     Json        @default("[]")
  createdAt DateTime    @default(now())

  session ConsultationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User                @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("consultation_messages")
}

model ConsultationReview {
  id        String   @id @default(uuid())
  bookingId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  booking ConsultationBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("consultation_reviews")
}

model CertificationType {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  standards   Json     @default("{}")
  validityMonths Int   @default(12)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications CertificationApplication[]

  @@map("certification_types")
}

model CertificationApplication {
  id        String                         @id @default(uuid())
  typeId    String
  applicantId String
  farmId    String
  status    CertificationApplicationStatus @default(DRAFT)
  formData  Json                           @default("{}")
  documents Json                           @default("[]")
  submittedAt DateTime?
  reviewedAt DateTime?
  createdAt DateTime                       @default(now())
  updatedAt DateTime                       @updatedAt

  type       CertificationType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  applicant  User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  farm       Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  inspections CertificationInspection[]
  certificate FarmCertificate?

  @@index([applicantId, status, createdAt])
  @@index([farmId, status])
  @@map("certification_applications")
}

model CertificationInspection {
  id            String           @id @default(uuid())
  applicationId String
  inspectorId   String
  status        InspectionStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  checklist     Json             @default("{}")
  report        Json             @default("{}")
  gpsTrace      Json?
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  application CertificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  inspector   User                     @relation(fields: [inspectorId], references: [id], onDelete: Cascade)

  @@index([inspectorId, status, scheduledAt])
  @@index([applicationId])
  @@map("certification_inspections")
}

model FarmCertificate {
  id            String            @id @default(uuid())
  applicationId String            @unique
  farmId        String
  ownerId       String
  certificateNo String            @unique
  qrToken       String            @unique
  pdfUrl        String?
  status        CertificateStatus @default(ISSUED)
  issuedAt      DateTime          @default(now())
  expiresAt     DateTime?
  metadata      Json              @default("{}")

  application CertificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  farm        Farm                     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  owner       User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([farmId, status])
  @@index([ownerId, status])
  @@map("farm_certificates")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      String
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(QUEUED)
  title     String
  body      String
  data      Json                @default("{}")
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([status, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(uuid())
  userId    String
  type      String
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  quietHours Json?
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@map("notification_preferences")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  platform  String
  token     String   @unique
  locale    String   @default("km-KH")
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@map("device_tokens")
}

model OutboxEvent {
  id          String            @id @default(uuid())
  type        String
  aggregateId String?
  payload     Json
  status      OutboxEventStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?
  createdAt   DateTime          @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@map("outbox_events")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  resource  String
  resourceId String?
  ipAddress String?
  userAgent String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}
