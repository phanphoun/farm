# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — backend/.env.production.example
# Copy to .env on your server and replace every value marked CHANGE_ME.
# All services are required in production.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000
API_PREFIX=api
CORS_ORIGINS=https://yourdomain.com

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/farmjumnoy?schema=public&sslmode=require

# ── JWT (REQUIRED — use long random strings) ──────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_random
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ── Redis / BullMQ (REQUIRED in production) ───────────────────────────────────
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── Meilisearch (REQUIRED in production) ─────────────────────────────────────
MEILI_HOST=https://your-meilisearch-host
MEILI_MASTER_KEY=CHANGE_ME

# ── Qdrant vector DB (REQUIRED in production) ────────────────────────────────
QDRANT_URL=https://your-qdrant-host
QDRANT_API_KEY=CHANGE_ME
QDRANT_COLLECTION=farmjumnoy_knowledge

# ── Object storage / S3 (REQUIRED in production) ─────────────────────────────
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_REGION=ap-southeast-1
S3_BUCKET=farmjumnoy-prod
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_FORCE_PATH_STYLE=false
CDN_BASE_URL=https://cdn.yourdomain.com

# ── AI provider ──────────────────────────────────────────────────────────────
# FREE option: Google Gemini Flash (recommended)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=CHANGE_ME
AI_PROVIDER=gemini

# Paid alternatives (uncomment and set AI_PROVIDER accordingly):
# OPENAI_API_KEY=sk-...          # AI_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-...   # AI_PROVIDER=anthropic
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_CONTEXT_CHUNKS=6
AI_LOW_CONFIDENCE_THRESHOLD=0.55

# ── OTP / email ───────────────────────────────────────────────────────────────
OTP_DEV_MODE=false
OTP_TTL_MINUTES=10
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=CHANGE_ME
# SMTP_PASS=CHANGE_ME
# SMTP_FROM=noreply@yourdomain.com
